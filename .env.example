# ===========================================
#   CREWGO — FRONTEND · VARIABLES DE ENTORNO
#   Copia este archivo a .env y rellena los
#   valores. Nunca subas .env a git.
# ===========================================


# -------------------------------------------
#  BACKEND · URL de conexión
#
#  Tienes dos opciones (no hace falta usar las dos):
#
#  OPCIÓN A — Dev: define host y puerto por separado.
#  La URL se construye como http://{HOST}:{PORT}
#
#  OPCIÓN B — Prod: define la URL completa.
#  Si VITE_API_URL está rellena, ignora host y puerto.
#
#  · Dev local   → deja VITE_API_URL vacío
#  · Producción  → rellena solo VITE_API_URL
# -------------------------------------------

#  Opción A · dev
VITE_BACK_HOST=localhost
VITE_BACK_PORT=3000

#  Opción B · prod (Netlify u otro hosting)
#  Ejemplo: https://tu-backend.onrender.com
VITE_API_URL=


# -------------------------------------------
#  CLOUDINARY · necesario para la subida de imágenes
#  Mismo valor que CLOUDINARY_CLOUD_NAME del backend
# -------------------------------------------

VITE_CLOUDINARY_CLOUD_NAME=
